# Server
NODE_ENV=development
PORT=3000
SESSION_SECRET=change-this-to-a-random-string-at-least-32-chars

# Database
DATABASE_URL=postgresql://turbomailer:turbomailer_pass@localhost:5432/turbomailer

# Redis
REDIS_URL=redis://localhost:6379

# Encryption key for SMTP passwords (32 hex chars)
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef

# JWT
JWT_SECRET=my_super_secret_key_12345
JWT_EXPIRY=7d

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# Default Throttle (emails per minute)
DEFAULT_THROTTLE=30

# Upload limits
MAX_FILE_SIZE=10485760

# WebSocket
WS_PORT=3001

# Tracking domain (for open/click tracking)
TRACKING_DOMAIN=http://localhost:3000